# Copy to .env and fill in. NEVER commit .env.
# Two modes — pick ONE:

# ── Mode A: Cognee Cloud (Option B) ──────────────────────────────────────────
# Set BOTH of these to route memory + generation to your managed Cognee tenant.
# Inference is then billed to your Cognee credits, so NO separate LLM key is
# needed (leave the Gemini block below blank/commented). Get the URL + key
# (ck_...) from the Cognee Cloud console → API Keys.
# COGNEE_SERVICE_URL=https://your-tenant.aws.cognee.ai
# COGNEE_API_KEY=ck_your_cognee_key_here

# ── Mode B: Local (default) ──────────────────────────────────────────────────
# Used when the COGNEE_* vars above are unset. cognee runs in-process and uses
# this Gemini key for both generation and embeddings (via LiteLLM).
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash-lite
LLM_API_KEY=your-gemini-key-here

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_API_KEY=your-gemini-key-here
