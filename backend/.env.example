# Copy to .env and fill in. NEVER commit .env.

# ── Generation backend (optional) ───────────────────────────────────────────
# Default: unset — cognee generates the dialogue (recall generation mode).
# Either backend below keeps cognee for MEMORY ONLY (writes + retrieval +
# per-NPC scoping) and generates the words directly — much lower latency.

# Option 1: local model via Ollama (free, offline; `ollama pull llama3.1:8b`)
# LLM_BACKEND=ollama
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_URL=http://127.0.0.1:11434

# Option 2: GLM 5 on Amazon Bedrock (API key from Bedrock console → API keys,
# with model access enabled for zai.glm-5 in your region)
# LLM_BACKEND=bedrock
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key
# BEDROCK_REGION=ap-south-1
# BEDROCK_MODEL_ID=zai.glm-5

# Memory modes — pick ONE:

# ── Mode A: Cognee Cloud (Option B) ──────────────────────────────────────────
# Set BOTH of these to route memory + generation to your managed Cognee tenant.
# Inference is then billed to your Cognee credits, so NO separate LLM key is
# needed (leave the Gemini block below blank/commented). Get the URL + key
# (ck_...) from the Cognee Cloud console → API Keys.
# COGNEE_SERVICE_URL=https://your-tenant.aws.cognee.ai
# COGNEE_API_KEY=ck_your_cognee_key_here

# ── Mode B: Local (default) ──────────────────────────────────────────────────
# Used when the COGNEE_* vars above are unset. cognee runs in-process and uses
# this Gemini key for both generation and embeddings (via LiteLLM).
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash-lite
LLM_API_KEY=your-gemini-key-here

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_API_KEY=your-gemini-key-here
