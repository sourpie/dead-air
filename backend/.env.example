# Copy to .env and fill in. NEVER commit .env.

# ── cognee feature toggles (all default ON in local mode) ────────────────────
# The graph pipeline (add+cognify+search) unlocks node_set metadata, temporal
# reasoning, ontology grounding, memify enrichment and feedback ranking. Turn
# individual passes OFF (=0) if you are quota-constrained — the game still runs.
# NPCMEM_GRANULAR=1          # 0 => use the remember()/recall() wrapper path
# NPCMEM_TEMPORAL=1          # temporal_cognify on the seed pass (Event/Timestamp nodes)
# NPCMEM_ONTOLOGY=1          # OWL grounding via station.owl (ontology_valid)
# NPCMEM_MEMIFY=1            # post-seed enrichment pass
# NPCMEM_FEEDBACK_INFLUENCE=0.3   # 0..1: how much feedback edge-weights bias recall
# NPCMEM_FEEDBACK_LEARN=0    # 1 => on a solved case, write feedback + improve() (LLM-heavy)
# NPCMEM_EXTRACTION_PROMPT=0 # 1 => steer cognify extraction with a station-domain prompt
#                            #      (test with verify_live.py first — a bad prompt weakens seeds)
# COGNEE_SKIP_CONNECTION_TEST=true  # set by config.py; skips the 30s LLM pre-flight probe


# ── Generation backend (optional) ───────────────────────────────────────────
# Default: unset — cognee generates the dialogue (recall generation mode).
# Set LLM_BACKEND=bedrock to keep cognee for MEMORY ONLY (writes + retrieval +
# per-NPC scoping) and generate the words with GLM 5 on Amazon Bedrock — much
# lower latency. Get a Bedrock API key from the Bedrock console → API keys,
# and enable model access for zai.glm-5 in your region.
# LLM_BACKEND=bedrock
# AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key
# BEDROCK_REGION=ap-south-1
# BEDROCK_MODEL_ID=zai.glm-5

# Memory modes — pick ONE:

# ── Mode A: Cognee Cloud (Option B) ──────────────────────────────────────────
# Set BOTH of these to route memory + generation to your managed Cognee tenant.
# Inference is then billed to your Cognee credits, so NO separate LLM key is
# needed (leave the Gemini block below blank/commented). Get the URL + key
# (ck_...) from the Cognee Cloud console → API Keys.
# COGNEE_SERVICE_URL=https://your-tenant.aws.cognee.ai
# COGNEE_API_KEY=ck_your_cognee_key_here

# ── Mode B: Local (default) ──────────────────────────────────────────────────
# Used when the COGNEE_* vars above are unset. cognee runs in-process and uses
# this Gemini key for both generation and embeddings (via LiteLLM).
LLM_PROVIDER=gemini
LLM_MODEL=gemini/gemini-2.5-flash-lite
LLM_API_KEY=your-gemini-key-here

EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=gemini/gemini-embedding-001
EMBEDDING_DIMENSIONS=3072
EMBEDDING_API_KEY=your-gemini-key-here
